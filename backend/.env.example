# SickleCare Cameroon — Environment Variables
# Copy to .env and fill in real values.
# Load via: SetEnv directives in .htaccess, or php-fpm pool env vars.

APP_ENV=production
APP_URL=https://sicklecare.cm
FRONTEND_URL=https://sicklecare.cm

DB_HOST=localhost
DB_PORT=3306
DB_NAME=sicklecare_db
DB_USER=sicklecare_user
DB_PASS=CHANGE_TO_STRONG_PASSWORD

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_TO_64_CHARACTER_RANDOM_STRING

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@sicklecare.cm
MAIL_PASS=your_smtp_app_password
MAIL_ADMIN=admin@sicklecare.cm
