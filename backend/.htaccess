# SickleCare Backend — Apache Security Configuration
Options -Indexes -ExecCGI
ServerSignature Off

# Deny access to sensitive files
<FilesMatch "\.(sql|log|json|md|sh|env|bak|backup|config|ini|conf)$">
    Require all denied
</FilesMatch>

# Block access to hidden files and directories
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Only allow PHP files to be executed
<FilesMatch "\.php$">
    Options -ExecCGI
</FilesMatch>

# Prevent direct access to non-API directories
<DirectoryMatch "(config|middleware|utils|logs|uploads)">
    Require all denied
</DirectoryMatch>

# Block common exploit attempts
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block suspicious user agents
    RewriteCond %{HTTP_USER_AGENT} (curl|wget|python|perl|ruby|java|go-http-client|libwww|nikto|nessus|masscan) [NC]
    RewriteRule .* - [F,L]

    # Block requests with no user agent
    RewriteCond %{HTTP_USER_AGENT} ^$
    RewriteRule .* - [F,L]

    # Enforce HTTPS in production
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Only allow GET and POST
    RewriteCond %{REQUEST_METHOD} !^(GET|POST|OPTIONS)$
    RewriteRule .* - [F,L]
</IfModule>

# Rate limiting via mod_evasive (if available)
# <IfModule mod_evasive24.c>
#     DOSHashTableSize 3097
#     DOSPageCount 10
#     DOSSiteCount 100
#     DOSPageInterval 1
#     DOSSiteInterval 1
#     DOSBlockingPeriod 600
# </IfModule>

# Security headers (supplement PHP headers)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# Compress responses
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json text/plain
</IfModule>

# Cache control
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType application/json "access plus 0 seconds"
</IfModule>
