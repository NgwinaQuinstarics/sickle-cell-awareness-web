# SickleCare Cameroon — Apache Security Configuration

Options -Indexes -ExecCGI -MultiViews
ServerSignature Off

# Block access to sensitive file types
<FilesMatch "\.(sql|log|json|md|sh|env|bak|ini|conf|lock|txt|yaml|yml)$">
    Require all denied
</FilesMatch>

# Block hidden files and directories (.env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Deny direct access to all non-API directories
<DirectoryMatch "^.*(config|middleware|utils|logs|uploads|tests|vendor).*$">
    Require all denied
</DirectoryMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Only allow GET, POST, OPTIONS
    RewriteCond %{REQUEST_METHOD} !^(GET|POST|OPTIONS)$
    RewriteRule .* - [F,L]

    # Block empty User-Agents (most bots)
    RewriteCond %{HTTP_USER_AGENT} ^$
    RewriteRule .* - [F,L]

    # Block known scanners and attack tools
    RewriteCond %{HTTP_USER_AGENT} (nikto|sqlmap|nmap|dirbuster|gobuster|masscan|hydra|wfuzz) [NC]
    RewriteRule .* - [F,L]

    # Block path traversal
    RewriteCond %{QUERY_STRING} (\.\./|\.\.\\) [NC]
    RewriteRule .* - [F,L]

    # Block SQL injection patterns in query string
    RewriteCond %{QUERY_STRING} (union\+select|drop\+table|insert\+into|<script|%27|%3C%3E) [NC]
    RewriteRule .* - [F,L]

    # Force HTTPS — uncomment when SSL certificate is active
    # RewriteCond %{HTTPS} off
    # RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Security response headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options         "DENY"
    Header always set X-XSS-Protection        "1; mode=block"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"
    Header always set Permissions-Policy      "geolocation=(), microphone=(), camera=()"
    Header always unset Server
    Header always unset X-Powered-By
</IfModule>

# Gzip compression for API responses
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE application/json text/plain
</IfModule>

# No caching for API responses
<IfModule mod_headers.c>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# PHP hardening (if using mod_php)
<IfModule mod_php.c>
    php_flag  display_errors          Off
    php_flag  log_errors              On
    php_value error_log               ../logs/php-error.log
    php_flag  allow_url_include       Off
    php_flag  allow_url_fopen         Off
    php_flag  session.cookie_httponly On
    php_flag  session.cookie_secure   On
    php_value session.cookie_samesite Strict
    php_value upload_max_filesize     2M
    php_value post_max_size           2M
    php_value max_execution_time      30
    php_value memory_limit            64M
</IfModule>
